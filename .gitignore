# =============================================================================
#                     DOTFILES REPOSITORY GITIGNORE
# =============================================================================

# Exclude project-specific aliases (contains personal/sensitive project info)
bash/.bash_aliases_projects

# Exclude any generated/compiled files
**/packer_compiled.lua

# Exclude tmux plugins (managed by tpm)

# Exclude test and development files
**/*_test.*
**/package*.json
config_test/

# Editor temp files (just in case)
*.swp
*.swo
*~
.*.sw?
*.log

ssh/.ssh/*
!ssh/.ssh/config

# Claude Code - ignore local/sensitive files
claude/.claude/.credentials.json
claude/.claude/backups/
claude/.claude/cache/
claude/.claude/sessions/
claude/.claude/shell-snapshots/
claude/.claude/history.jsonl
claude/.claude/mcp-needs-auth-cache.json
claude/.claude/plugins/
claude/.claude/projects/

# BUT keep these treasures!
!claude/.claude/CLAUDE.md
!claude/.claude/settings.json
!claude/.claude/settings.example.json
!claude/.claude/scripts/
