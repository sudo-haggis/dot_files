{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "attribution": {
    "gitCommitMessage": "Co-authored-by: Claude <claude@anthropic.com>",
    "gitTrailer": ""
  },
  "permissions": {
    "allow": [],
    "deny": [
      "Edit(~/.ssh/*)",
      "Edit(~/.aws/*)",
      "Edit(~/.gnupg/*)",
      "Edit(~/.bashrc)",
      "Edit(~/.zshrc)",
      "Edit(~/.dotfiles/*)",
      "Read(~/.ssh/*)",
      "Read(~/.aws/*)",
      "Read(~/.gnupg/*)",
      "Read(.env)",
      "Read(.env.*)"
    ]
  },
  "sandbox": {
    "enabled": true,
    "autoAllowBashIfSandboxed": false
  }
}
