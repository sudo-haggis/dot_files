{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "attribution": {},
  "permissions": {
    "allow": [
      "Bash(git *)",
      "Bash(node *)"
    ],
    "deny": [
      "Edit(~/.ssh/*)",
      "Edit(~/.aws/*)",
      "Edit(~/.gnupg/*)",
      "Edit(~/.bashrc)",
      "Edit(~/.zshrc)",
      "Edit(~/.dotfiles/*)",
      "Read(~/.ssh/*)",
      "Read(~/.aws/*)",
      "Read(~/.gnupg/*)",
      "Read(.env)",
      "Read(.env.*)"
    ]
  },
  "sandbox": {
    "enabled": true,
    "autoAllowBashIfSandboxed": false
  },
  "theme": "dark-daltonized"
}
